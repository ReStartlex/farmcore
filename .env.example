# Telegram-бот для приёма заявок с сайта.
# Токен берётся у @BotFather.
Bot_Token=ваш_токен_бота

# Куда отправлять заявки (ваш личный chat_id, число).
# Как узнать: напишите своему боту любое сообщение, затем я определю chat_id
# (или откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates и найдите "chat":{"id":...}).
LEAD_CHAT_ID=

# Прокси для отправки в Telegram (если с РУ-хостинга api.telegram.org недоступен).
# Форматы: http://user:pass@host:port  или  http://host:port
TELEGRAM_PROXY=

# ID счётчика Яндекс.Метрики (только число). Без него аналитика отключена.
NEXT_PUBLIC_YM_ID=

# Код подтверждения прав в Яндекс.Вебмастере (значение content из мета-тега
# <meta name="yandex-verification" content="...">). Нужен для индексации в Яндексе.
YANDEX_VERIFICATION=

# Код подтверждения прав в Google Search Console (значение content из мета-тега
# <meta name="google-site-verification" content="...">). Нужен для индексации в Google.
GOOGLE_VERIFICATION=
